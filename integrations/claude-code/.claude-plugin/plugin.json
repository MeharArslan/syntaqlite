{
  "name": "syntaqlite",
  "version": "0.0.24",
  "description": "SQLite SQL language server — diagnostics, formatting, completions, and semantic tokens",
  "author": {
    "name": "Lalit Maganti"
  },
  "homepage": "https://syntaqlite.com",
  "repository": "https://github.com/LalitMaganti/syntaqlite",
  "license": "Apache-2.0",
  "keywords": ["sql", "sqlite", "lsp", "formatter", "linter"],
