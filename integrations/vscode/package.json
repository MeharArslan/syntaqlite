{
  "name": "syntaqlite",
  "displayName": "syntaqlite",
  "description": "SQL language support powered by syntaqlite — diagnostics, formatting, completions, and semantic highlighting",
  "version": "0.0.32",
  "publisher": "syntaqlite",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LalitMaganti/syntaqlite"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "sql",
    "sqlite",
    "formatter",
    "linter",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:sqlite",
    "onCommand:syntaqlite.restartServer",
    "onCommand:syntaqlite.formatDocument",
    "onCommand:syntaqlite.openConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sqlite",
        "extensions": [
          ".sqlite.sql"
        ],
        "aliases": [
          "SQLite",
          "SQL (SQLite)"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sqlite",
        "scopeName": "source.sql.sqlite",
        "path": "./syntaxes/sqlite.tmLanguage.json",
        "semanticHighlighting": true
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[sql]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[sqlite]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "commands": [
      {
        "command": "syntaqlite.restartServer",
        "title": "syntaqlite: Restart Language Server"
      },
      {
        "command": "syntaqlite.formatDocument",
        "title": "syntaqlite: Format Document"
      },
      {
        "command": "syntaqlite.openConfig",
        "title": "syntaqlite: Open Config File"
      }
    ],
    "configuration": {
      "title": "syntaqlite",
      "properties": {
        "syntaqlite.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the syntaqlite binary. Leave empty to use the bundled binary or PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package",
    "package:target": "node scripts/package-target.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
