# Build targets for third-party source code.

executable("lemon") {
  sources = [ "src/sqlite/tool/lemon.c" ]
}

config("mkkeywordhash_config") {
  cflags = [
    "-Wno-missing-field-initializers",
    "-Wno-unused-parameter",
    "-Wno-sign-compare",
  ]
}

executable("mkkeywordhash") {
  sources = [ "src/sqlite/tool/mkkeywordhash.c" ]
  configs += [ ":mkkeywordhash_config" ]
}
