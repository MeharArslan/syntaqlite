enum SortOrder { ASC DESC }
enum NullsOrder { NONE FIRST LAST }

flags ResultColumnFlags { STAR = 1 }
flags SelectStmtFlags { DISTINCT = 1 }

node ResultColumn {
  flags: inline ResultColumnFlags
  alias: index Name
  expr: index Expr

  semantic { result_column(flags: flags, alias: alias, expr: expr) }

  fmt {
    if_flag(flags.star) {
      if_set(expr) { child_paren_list(expr) ".*" } else { "*" }
    } else {
      child_paren_list(expr)
    }
    if_set(alias) { " AS " child(alias) }
  }
}

list ResultColumnList { ResultColumn }

node SelectStmt {
  flags: inline SelectStmtFlags
  columns: index ResultColumnList
  from_clause: index TableSource
  where_clause: index Expr
  groupby: index ExprList
  having: index Expr
  orderby: index OrderByList
  limit_clause: index LimitClause
  window_clause: index NamedWindowDefList

  semantic { query(from: from_clause, columns: columns, where_clause: where_clause, groupby: groupby, having: having, orderby: orderby, limit_clause: limit_clause) }

  fmt {
    group {
      if_flag(flags.distinct) { "SELECT DISTINCT" } else { "SELECT" }
      if_set(columns) { group { nest { line child(columns) } } }
      if_set(from_clause) { line "FROM " child(from_clause) }
      clause("WHERE", where_clause)
      clause("GROUP BY", groupby)
      clause("HAVING", having)
      clause("ORDER BY", orderby)
      clause("LIMIT", limit_clause)
      clause("WINDOW", window_clause)
    }
  }
}

node OrderingTerm {
  expr: index Expr
  sort_order: inline SortOrder
  nulls_order: inline NullsOrder

  fmt {
    child_paren_list(expr)
    if_enum(sort_order, DESC) { " DESC" }
    if_enum(nulls_order, FIRST) { " NULLS FIRST" }
    if_enum(nulls_order, LAST) { " NULLS LAST" }
  }
}

list OrderByList { OrderingTerm }

node LimitClause {
  limit: index Expr
  offset: index Expr

  fmt {
    child(limit)
    if_set(offset) { " OFFSET " child(offset) }
  }
}
