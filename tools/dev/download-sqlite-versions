#!/usr/bin/env bash
# Download SQLite source files from the GitHub mirror for multiple versions.
#
# Usage:
#   ./tools/dev/download-sqlite-versions [OUTPUT_DIR] [VERSION...]
#
# If no versions are given, downloads a default set covering major feature
# boundaries. Sources are fetched from:
#   https://raw.githubusercontent.com/sqlite/sqlite/version-X.Y.Z/...
#
# Output layout:
#   OUTPUT_DIR/3.35.0/src/tokenize.c
#   OUTPUT_DIR/3.35.0/src/global.c
#   OUTPUT_DIR/3.35.0/src/sqliteInt.h
#   OUTPUT_DIR/3.35.0/tool/mkkeywordhash.c

set -euo pipefail

DEFAULT_VERSIONS=(
    3.12.2
    3.13.0
    3.14.2
    3.15.2
    3.16.2
    3.17.0
    3.18.2
    3.19.4
    3.20.1
    3.21.0
    3.22.0
    3.23.2
    3.24.0
    3.25.3
    3.26.0
    3.27.2
    3.28.0
    3.29.0
    3.30.1
    3.31.1
    3.32.3
    3.33.0
    3.34.1
    3.35.5
    3.36.0
    3.37.2
    3.38.5
    3.39.4
    3.40.1
    3.41.2
    3.42.1
    3.43.2
    3.44.5
    3.45.3
    3.46.1
    3.47.2
    3.48.0
    3.49.2
    3.50.4
    3.51.2
)

FILES=(
    src/tokenize.c
    src/global.c
    src/sqliteInt.h
    src/parse.y
    tool/mkkeywordhash.c
)

BASE_URL="https://raw.githubusercontent.com/sqlite/sqlite"

output_dir="${1:-sqlite-sources}"
shift 2>/dev/null || true

if [ $# -gt 0 ]; then
    versions=("$@")
else
    versions=("${DEFAULT_VERSIONS[@]}")
fi

echo "Downloading ${#versions[@]} SQLite versions to ${output_dir}/"

failed=0
for ver in "${versions[@]}"; do
    tag="version-${ver}"
    dir="${output_dir}/${ver}"
    mkdir -p "${dir}/src" "${dir}/tool"

    all_ok=true
    for f in "${FILES[@]}"; do
        dest="${dir}/${f}"
        if [ -f "${dest}" ]; then
            continue
        fi
        url="${BASE_URL}/${tag}/${f}"
        if ! curl -sfL "${url}" -o "${dest}"; then
            echo "  FAILED: ${ver}/${f}" >&2
            rm -f "${dest}"
            all_ok=false
            failed=$((failed + 1))
        fi
    done

    if $all_ok; then
        echo "  ${ver}: ok"
    fi
done

if [ $failed -gt 0 ]; then
    echo "${failed} file(s) failed to download" >&2
    exit 1
fi

echo "Done. Sources in ${output_dir}/"
