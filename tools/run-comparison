#!/usr/bin/env python3
"""
Run the competitive comparison and optionally write markdown to docs.

Usage:
  tools/run-comparison --setup                # install all competitor tools
  tools/run-comparison                        # run all categories, save JSON results
  tools/run-comparison parser formatter       # run specific categories
  tools/run-comparison --markdown             # generate markdown from cached JSON
  tools/run-comparison --all                  # run + generate markdown in one step
"""

import argparse
import os
import shutil
import subprocess
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
REPO = os.path.normpath(os.path.join(SCRIPT_DIR, ".."))
COMP_DIR = os.path.join(REPO, "tests", "comparison")
DOCS_DIR = os.path.join(REPO, "web", "docs", "content", "reference")

# Add python/ to path so we can import comparison modules
sys.path.insert(0, os.path.join(REPO, "python"))


# ── Setup ──────────────────────────────────────────────────────────

def do_setup():
    print("==> Installing comparison dependencies...\n")

    def _sh(cmd, **kw):
        subprocess.run(cmd, shell=True, check=True, **kw)

    # 1. npm local deps
    print("--- npm install (tests/comparison/) ---")
    _sh("npm install", cwd=COMP_DIR)
    print()

    # 2. npm global tools
    print("--- npm install global tools ---")
    _sh("npm install -g sql-formatter sql-language-server")
    print()

    # 3. Python deps via uv
    print("--- uv sync (tests/comparison/) ---")
    if not shutil.which("uv"):
        print("ERROR: 'uv' not found. Install: https://docs.astral.sh/uv/getting-started/installation/")
        sys.exit(1)
    _sh("uv sync", cwd=COMP_DIR)
    print()

    # 4. Rust parser benchmarks
    print("--- cargo build (tests/comparison/parser/) ---")
    _sh(f"cargo build --release --manifest-path {COMP_DIR}/parser/Cargo.toml "
        f"--target-dir {COMP_DIR}/parser/target")
    print()

    # 5. Cargo-installed tools
    print("--- cargo install (sleek) ---")
    subprocess.run("cargo install sleek", shell=True, stderr=subprocess.DEVNULL)
    print()

    # 6. Homebrew tools
    print("--- brew install (sqruff, hyperfine) ---")
    for tool in ["sqruff", "hyperfine"]:
        if shutil.which(tool):
            print(f"{tool} already installed")
        else:
            _sh(f"brew install {tool}")
    print()

    # 7. Go tools
    print("--- go install (sqls) ---")
    if shutil.which("go"):
        subprocess.run("go install github.com/sqls-server/sqls@latest",
                       shell=True, stderr=subprocess.DEVNULL)
    else:
        print("WARN: 'go' not found, skipping sqls install")
    print()

    # 8. Build syntaqlite
    print("--- building syntaqlite CLI ---")
    _sh(f"{REPO}/tools/cargo build --release -p syntaqlite-cli")
    print()

    print("==> Setup complete.")


# ── Preflight ──────────────────────────────────────────────────────

def check_deps():
    missing = []

    if not os.access(os.path.join(REPO, "target", "release", "syntaqlite"), os.X_OK):
        missing.append("syntaqlite (run: tools/cargo build --release -p syntaqlite-cli)")

    if not os.access(os.path.join(COMP_DIR, "parser", "target", "release", "lemon-rs-parse"), os.X_OK):
        missing.append("lemon-rs-parse (run: cargo build --release --manifest-path tests/comparison/parser/Cargo.toml)")

    if not os.access(os.path.join(COMP_DIR, "parser", "target", "release", "sqlparser-parse"), os.X_OK):
        missing.append("sqlparser-parse")

    if not os.path.isdir(os.path.join(COMP_DIR, "node_modules", "sql-parser-cst")):
        missing.append("sql-parser-cst (run: cd tests/comparison && npm install)")

    if not os.path.isdir(os.path.join(COMP_DIR, "node_modules", "node-sql-parser")):
        missing.append("node-sql-parser")

    if not shutil.which("sql-formatter"):
        missing.append("sql-formatter (run: npm install -g sql-formatter)")

    if not shutil.which("hyperfine"):
        missing.append("hyperfine (run: brew install hyperfine)")

    if not shutil.which("uv"):
        missing.append("uv (install: https://docs.astral.sh/uv/)")

    if missing:
        print("ERROR: Missing comparison dependencies:", file=sys.stderr)
        for dep in missing:
            print(f"  - {dep}", file=sys.stderr)
        print("\nRun 'tools/run-comparison --setup' to install all dependencies.", file=sys.stderr)
        sys.exit(1)


# ── Main ──────────────────────────────────────────────────────────

ALL_CATEGORIES = ["parser", "formatter", "validator", "lsp"]


def main():
    parser = argparse.ArgumentParser(
        description="syntaqlite competitive comparison",
        usage="tools/run-comparison [--setup | --markdown | --all] [categories...]",
    )
    parser.add_argument("categories", nargs="*", default=ALL_CATEGORIES,
                        help="Categories to run (parser, formatter, validator, lsp)")
    parser.add_argument("--setup", action="store_true",
                        help="Install all competitor tool dependencies")
    parser.add_argument("--markdown", action="store_true",
                        help="Generate markdown docs from cached JSON results")
    parser.add_argument("--all", action="store_true",
                        help="Run comparisons and generate markdown in one step")
    args = parser.parse_args()

    if args.setup:
        do_setup()
        return

    from syntaqlite.comparison.collect import collect_all, load_results
    from syntaqlite.comparison.render import write_docs

    if args.markdown:
        # Just render from cached JSON
        results = load_results(args.categories)
        if not results:
            print("No cached results found. Run without --markdown first.", file=sys.stderr)
            sys.exit(1)
        write_docs(results, DOCS_DIR)
        return

    # Default: run comparisons and save JSON
    check_deps()
    results = collect_all(args.categories)

    if args.all:
        write_docs(results, DOCS_DIR)


if __name__ == "__main__":
    main()
