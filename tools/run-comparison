#!/usr/bin/env bash
# Run the competitive comparison and optionally write markdown to docs.
#
# Usage:
#   tools/run-comparison                       # terminal output, all categories
#   tools/run-comparison validator             # terminal output, one category
#   tools/run-comparison --markdown            # write markdown to web/docs/content/reference/
#   tools/run-comparison --markdown validator  # write one category to docs

set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$DIR/.." && pwd)"
DOCS_DIR="$REPO/web/docs/content/reference"
RUNNER="$REPO/python/syntaqlite/comparison/run.py"

output_mode="terminal"
categories=()

for arg in "$@"; do
    case "$arg" in
        --markdown|-m)
            output_mode="markdown"
            ;;
        *)
            categories+=("$arg")
            ;;
    esac
done

if [ "$output_mode" = "markdown" ]; then
    summary_file="$DOCS_DIR/comparison.md"
    detail_file="$DOCS_DIR/comparison-details.md"
    mkdir -p "$DOCS_DIR"

    summary_frontmatter='+++
title = "Competitive Comparison"
weight = 10
+++
'
    detail_frontmatter='+++
title = "Comparison Details"
weight = 11
+++
'

    echo "Running comparison (markdown mode)..."
    echo "Summary: $summary_file"
    echo "Details: $detail_file"
    echo ""

    python3 "$RUNNER" --output markdown \
        --output-file "$detail_file.tmp" \
        --summary-file "$summary_file.tmp" \
        "${categories[@]+"${categories[@]}"}"

    # Prepend Zola frontmatter to both files
    printf '%s' "$summary_frontmatter" > "$summary_file"
    cat "$summary_file.tmp" >> "$summary_file"
    rm -f "$summary_file.tmp"

    printf '%s' "$detail_frontmatter" > "$detail_file"
    cat "$detail_file.tmp" >> "$detail_file"
    rm -f "$detail_file.tmp"

    echo ""
    echo "Written to $summary_file"
    echo "Written to $detail_file"
else
    python3 "$RUNNER" "${categories[@]+"${categories[@]}"}"
fi
