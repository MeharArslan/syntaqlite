"""Download and run the syntaqlite CLI binary.

Downloads the binary to ~/.local/share/syntaqlite/ (Unix) or
%LOCALAPPDATA%\\syntaqlite\\ (Windows) on first run, then executes it.
Subsequent runs use the cached binary.

Usage:
    # Download and run directly:
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - fmt -e "select 1"

    # Install to ~/.local/bin (or %LOCALAPPDATA%\\syntaqlite on Windows):
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - --install

    # Force re-download (cache invalidation):
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - --update
"""

import io
import json
import os
import platform
import shutil
import stat
import subprocess
import sys
import tarfile
import urllib.request
import zipfile
from pathlib import Path

REPO = "LalitMaganti/syntaqlite"

TARGETS = {
    ("Darwin", "arm64"): "aarch64-apple-darwin",
    ("Darwin", "x86_64"): "x86_64-apple-darwin",
    ("Linux", "x86_64"): "x86_64-unknown-linux-gnu",
    ("Linux", "aarch64"): "aarch64-unknown-linux-gnu",
    ("Windows", "AMD64"): "x86_64-pc-windows-msvc",
}


def _cache_dir() -> Path:
    if platform.system() == "Windows":
        base = Path(os.environ.get("LOCALAPPDATA", Path.home() / "AppData" / "Local"))
    else:
        base = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share"))
    return base / "syntaqlite"


def _install_dir() -> Path:
    if platform.system() == "Windows":
        return _cache_dir()
    return Path.home() / ".local" / "bin"


def _binary_name() -> str:
    return "syntaqlite.exe" if platform.system() == "Windows" else "syntaqlite"


def _detect_target() -> str:
    key = (platform.system(), platform.machine())
    if key not in TARGETS:
        sys.exit(f"Unsupported platform: {key[0]} {key[1]}")
    return TARGETS[key]


def _latest_version() -> str:
    """Fetch the latest release tag from GitHub."""
    url = f"https://api.github.com/repos/{REPO}/releases/latest"
    req = urllib.request.Request(url, headers={"Accept": "application/vnd.github+json"})
    data = json.loads(urllib.request.urlopen(req).read())
    return data["tag_name"]


def _cached_version(cache_dir: Path) -> str | None:
    version_file = cache_dir / "version"
    if version_file.exists():
        return version_file.read_text().strip()
    return None


def _save_version(cache_dir: Path, version: str) -> None:
    cache_dir.mkdir(parents=True, exist_ok=True)
    (cache_dir / "version").write_text(version)


def _download(target: str, dest: Path) -> None:
    is_windows = "windows" in target
    binary_name = _binary_name()
    archive = f"syntaqlite-cli-{target}.{'zip' if is_windows else 'tar.xz'}"
    url = f"https://github.com/{REPO}/releases/latest/download/{archive}"

    print(f"Downloading syntaqlite ({target})...", file=sys.stderr)
    data = urllib.request.urlopen(url).read()

    if is_windows:
        with zipfile.ZipFile(io.BytesIO(data)) as zf:
            for name in zf.namelist():
                if name.endswith(binary_name):
                    dest.parent.mkdir(parents=True, exist_ok=True)
                    dest.write_bytes(zf.read(name))
                    return
    else:
        with tarfile.open(fileobj=io.BytesIO(data), mode="r:xz") as tf:
            for member in tf.getmembers():
                if member.name.endswith(binary_name):
                    f = tf.extractfile(member)
                    if f:
                        dest.parent.mkdir(parents=True, exist_ok=True)
                        dest.write_bytes(f.read())
                        dest.chmod(dest.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
                        return

    sys.exit("Binary not found in archive")


def _ensure_binary(force: bool = False) -> Path:
    """Ensure the binary is downloaded and up to date. Returns path."""
    cache = _cache_dir()
    binary = cache / _binary_name()

    if force or not binary.exists():
        latest = _latest_version()
        _download(_detect_target(), binary)
        _save_version(cache, latest)
        print(f"syntaqlite {latest} cached at {binary}", file=sys.stderr)
    return binary


def main():
    # Parse our own flags before passing the rest to the binary.
    args = sys.argv[1:]

    if "--update" in args:
        args.remove("--update")
        binary = _ensure_binary(force=True)
        if not args:
            return

    elif "--install" in args:
        args.remove("--install")
        binary = _ensure_binary()
        dest_dir = _install_dir()
        dest_dir.mkdir(parents=True, exist_ok=True)
        dest = dest_dir / _binary_name()
        shutil.copy2(str(binary), str(dest))
        print(f"Installed to {dest}", file=sys.stderr)
        if str(dest_dir) not in os.environ.get("PATH", ""):
            print(f"Note: add {dest_dir} to your PATH", file=sys.stderr)
        return

    else:
        binary = _ensure_binary()

    if platform.system() == "Windows":
        sys.exit(subprocess.call([str(binary)] + args))
    else:
        os.execvp(str(binary), [str(binary)] + args)


if __name__ == "__main__":
    main()
