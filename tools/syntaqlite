"""Download and run the syntaqlite CLI binary.

Downloads the binary to ~/.local/share/syntaqlite/ (Unix) or
%LOCALAPPDATA%\\syntaqlite\\ (Windows) on first run, then executes it.
Subsequent runs use the cached binary. Auto-checks for updates every 7 days.

Usage:
    # Download and run (caches binary, auto-updates weekly):
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - fmt -e "select 1"

    # Install permanently to ~/.local/bin (Unix) or %LOCALAPPDATA%\\Programs\\syntaqlite (Windows):
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - install

    # Install to a custom directory:
    curl -sSf https://raw.githubusercontent.com/LalitMaganti/syntaqlite/main/tools/syntaqlite | python3 - install /usr/local/bin
"""

import io
import json
import os
import platform
import stat
import subprocess
import sys
import tarfile
import time
import urllib.request
import zipfile
from pathlib import Path

REPO = "LalitMaganti/syntaqlite"
UPDATE_CHECK_INTERVAL = 7 * 24 * 60 * 60  # 7 days

TARGETS = {
    ("Darwin", "arm64"): "macos-arm64",
    ("Darwin", "x86_64"): "macos-x64",
    ("Linux", "x86_64"): "linux-x64",
    ("Linux", "aarch64"): "linux-arm64",
    ("Windows", "AMD64"): "windows-x64",
    ("Windows", "ARM64"): "windows-arm64",
}


def _cache_dir() -> Path:
    if platform.system() == "Windows":
        base = Path(os.environ.get("LOCALAPPDATA", Path.home() / "AppData" / "Local"))
    else:
        base = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share"))
    return base / "syntaqlite"


def _binary_name() -> str:
    return "syntaqlite.exe" if platform.system() == "Windows" else "syntaqlite"


def _detect_target() -> str:
    key = (platform.system(), platform.machine())
    if key not in TARGETS:
        sys.exit(f"Unsupported platform: {key[0]} {key[1]}")
    return TARGETS[key]


def _github_headers() -> dict:
    headers = {"Accept": "application/vnd.github+json"}
    token = os.environ.get("GITHUB_TOKEN") or os.environ.get("GH_TOKEN")
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers


def _find_release() -> dict:
    """Find the latest release. Includes drafts when SYNTAQLITE_INCLUDE_DRAFTS=1."""
    include_drafts = os.environ.get("SYNTAQLITE_INCLUDE_DRAFTS") == "1"
    if include_drafts:
        # List all releases (includes drafts) and pick the first one
        url = f"https://api.github.com/repos/{REPO}/releases?per_page=5"
        req = urllib.request.Request(url, headers=_github_headers())
        releases = json.loads(urllib.request.urlopen(req).read())
        if not releases:
            sys.exit("No releases found")
        return releases[0]
    else:
        url = f"https://api.github.com/repos/{REPO}/releases/latest"
        req = urllib.request.Request(url, headers=_github_headers())
        return json.loads(urllib.request.urlopen(req).read())


def _latest_version() -> str:
    return _find_release()["tag_name"]


def _download_asset(release: dict, asset_name: str) -> bytes:
    """Download a release asset by name, using the API for auth (works for drafts)."""
    for asset in release.get("assets", []):
        if asset["name"] == asset_name:
            headers = _github_headers()
            headers["Accept"] = "application/octet-stream"
            req = urllib.request.Request(asset["url"], headers=headers)
            return urllib.request.urlopen(req).read()
    # Fallback: try the direct download URL (works for published releases)
    tag = release["tag_name"]
    url = f"https://github.com/{REPO}/releases/download/{tag}/{asset_name}"
    return urllib.request.urlopen(url).read()


def _download(target: str, dest: Path, release: dict | None = None) -> None:
    is_windows = "windows" in target
    binary_name = _binary_name()
    archive = f"syntaqlite-{target}.{'zip' if is_windows else 'tar.gz'}"

    print(f"Downloading syntaqlite ({target})...", file=sys.stderr)
    if release:
        data = _download_asset(release, archive)
    else:
        url = f"https://github.com/{REPO}/releases/latest/download/{archive}"
        data = urllib.request.urlopen(url).read()

    if is_windows:
        with zipfile.ZipFile(io.BytesIO(data)) as zf:
            for name in zf.namelist():
                if name.endswith(binary_name):
                    dest.parent.mkdir(parents=True, exist_ok=True)
                    dest.write_bytes(zf.read(name))
                    return
    else:
        with tarfile.open(fileobj=io.BytesIO(data), mode="r:gz") as tf:
            for member in tf.getmembers():
                if member.name.endswith(binary_name):
                    f = tf.extractfile(member)
                    if f:
                        dest.parent.mkdir(parents=True, exist_ok=True)
                        dest.write_bytes(f.read())
                        dest.chmod(dest.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
                        return

    sys.exit("Binary not found in archive")


def _needs_update_check(cache: Path) -> bool:
    stamp = cache / ".last-check"
    if not stamp.exists():
        return True
    return (time.time() - stamp.stat().st_mtime) > UPDATE_CHECK_INTERVAL


def _touch_stamp(cache: Path) -> None:
    cache.mkdir(parents=True, exist_ok=True)
    (cache / ".last-check").write_text("")


def _read_version(cache: Path) -> str | None:
    f = cache / "version"
    return f.read_text().strip() if f.exists() else None


def _write_version(cache: Path, version: str) -> None:
    cache.mkdir(parents=True, exist_ok=True)
    (cache / "version").write_text(version)


def _ensure_binary() -> Path:
    cache = _cache_dir()
    binary = cache / _binary_name()

    if not binary.exists():
        # First download.
        release = _find_release()
        version = release["tag_name"]
        _download(_detect_target(), binary, release)
        _write_version(cache, version)
        _touch_stamp(cache)
        print(f"syntaqlite {version} cached at {binary}", file=sys.stderr)
        return binary

    # Binary exists — check for updates if stamp is stale.
    if _needs_update_check(cache):
        try:
            release = _find_release()
            latest = release["tag_name"]
            cached = _read_version(cache)
            if cached != latest:
                print(f"Updating syntaqlite {cached} → {latest}...", file=sys.stderr)
                _download(_detect_target(), binary, release)
                _write_version(cache, latest)
            _touch_stamp(cache)
        except Exception:
            # Network failure during update check — use cached binary.
            pass

    return binary


def _install_dir() -> Path:
    if platform.system() == "Windows":
        base = Path(os.environ.get("LOCALAPPDATA", Path.home() / "AppData" / "Local"))
        return base / "Programs" / "syntaqlite"
    else:
        return Path.home() / ".local" / "bin"


def _is_on_path(directory: Path) -> bool:
    return str(directory) in os.environ.get("PATH", "").split(os.pathsep)


def _install_command(custom_dir: str | None) -> None:
    target = _detect_target()
    release = _find_release()
    version = release["tag_name"]
    dest_dir = Path(custom_dir) if custom_dir else _install_dir()
    dest = dest_dir / _binary_name()

    if dest.exists():
        print(f"Updating syntaqlite at {dest}...", file=sys.stderr)
    else:
        print(f"Installing syntaqlite to {dest}...", file=sys.stderr)

    _download(target, dest, release)

    print(f"syntaqlite {version} installed to {dest}", file=sys.stderr)

    if not _is_on_path(dest_dir):
        if platform.system() == "Windows":
            print(
                f"\nAdd {dest_dir} to your PATH:\n"
                f'  setx PATH "%PATH%;{dest_dir}"',
                file=sys.stderr,
            )
        else:
            shell = os.environ.get("SHELL", "")
            if "fish" in shell:
                rc = "~/.config/fish/config.fish"
                line = f"fish_add_path {dest_dir}"
            elif "zsh" in shell:
                rc = "~/.zshrc"
                line = f'export PATH="{dest_dir}:$PATH"'
            else:
                rc = "~/.bashrc"
                line = f'export PATH="{dest_dir}:$PATH"'
            print(
                f"\nAdd {dest_dir} to your PATH:\n"
                f"  echo '{line}' >> {rc}",
                file=sys.stderr,
            )


def main():
    if sys.argv[1:2] == ["install"]:
        _install_command(sys.argv[2] if len(sys.argv) > 2 else None)
        return

    binary = _ensure_binary()

    if platform.system() == "Windows":
        sys.exit(subprocess.call([str(binary)] + sys.argv[1:]))
    else:
        os.execvp(str(binary), [str(binary)] + sys.argv[1:])


if __name__ == "__main__":
    main()
