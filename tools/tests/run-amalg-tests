"""Amalgamation integration tests.

Generates amalgamated C files for each dialect configuration, compiles
test binaries, and runs AST diff tests against them.

Dialect configurations:
  - sqlite: base grammar only (no extensions)
  - perfetto: base + extension .y/.synq files

Usage:
    tools/tests/run-amalg-tests [-v] [--filter PATTERN]
"""

import argparse
import os
import sys
import time

ROOT_DIR = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
sys.path.insert(0, ROOT_DIR)

from pathlib import Path

from python.syntaqlite.diff_tests.amalg_executor import (
    AmalgTestContext,
    DialectConfig,
)
from python.syntaqlite.diff_tests.test_executor import TestResult, execute_test
from python.syntaqlite.diff_tests.test_loader import load_all_tests
from python.syntaqlite.diff_tests.utils import Colors, colorize, format_diff


# Map test file names to dialect configurations.
DIALECT_CONFIGS = {
    "sqlite": DialectConfig(name="sqlite"),
    "perfetto": DialectConfig(
        name="perfetto",
        actions_dir=os.path.join(ROOT_DIR, "dialects/perfetto/actions"),
        nodes_dir=os.path.join(ROOT_DIR, "dialects/perfetto/nodes"),
    ),
}


def dialect_for_test(test_name: str) -> str:
    """Infer dialect from test suite class name."""
    suite_name = test_name.split(".")[0]
    lower = suite_name.lower()
    for dialect in DIALECT_CONFIGS:
        if dialect in lower:
            return dialect
    return "sqlite"


def main():
    parser = argparse.ArgumentParser(description="Run amalgamation integration tests")
    parser.add_argument("--binary", default="target/debug/syntaqlite-cli",
                        help="Path to syntaqlite-cli binary")
    parser.add_argument("--filter", help="Run only tests matching pattern")
    parser.add_argument("--rebaseline", action="store_true",
                        help="Print suggested output for failures")
    parser.add_argument("-v", "--verbose", action="count", default=0)
    args = parser.parse_args()

    root_dir = Path(ROOT_DIR)
    cli_binary = Path(args.binary)
    if not cli_binary.is_absolute():
        cli_binary = root_dir / cli_binary

    # Load test definitions.
    tests = load_all_tests(root_dir, args.filter, "tests/amalg_tests")
    if not tests:
        print("No tests to run.")
        return 0

    suites = set(name.split(".")[0] for name, _ in tests)

    # Build amalgamations and compile test binaries.
    ctx = AmalgTestContext(root_dir, cli_binary)
    try:
        # Pre-build all needed dialects.
        needed_dialects = set()
        for name, _ in tests:
            needed_dialects.add(dialect_for_test(name))

        for dialect_name in sorted(needed_dialects):
            config = DIALECT_CONFIGS.get(dialect_name)
            if not config:
                print(f"Unknown dialect: {dialect_name}", file=sys.stderr)
                return 1
            if args.verbose >= 1:
                print(f"Building {dialect_name} amalgamation...")
            try:
                ctx.get_binary(config)
            except RuntimeError as e:
                print(f"Error: {e}", file=sys.stderr)
                return 1
            if args.verbose >= 1:
                print(f"  {dialect_name}: OK")

        # Run tests.
        start_time = time.time()
        results = []
        failed_tests = []

        if args.verbose >= 1:
            print(f"[==========] Running {len(tests)} tests from {len(suites)} test suites.")

        for name, blueprint in tests:
            dialect_name = dialect_for_test(name)
            config = DIALECT_CONFIGS[dialect_name]
            binary = ctx.get_binary(config)

            result = execute_test(binary, name, blueprint)
            results.append(result)

            if result.passed:
                if args.verbose >= 2:
                    print(f"[ RUN      ] {name}")
                if args.verbose >= 1:
                    ok = colorize("[       OK ]", Colors.GREEN)
                    print(f"{ok} {name} ({result.elapsed_ms} ms)")
            else:
                if args.verbose >= 1:
                    failed = colorize("[  FAILED  ]", Colors.RED)
                    print(f"{failed} {name} ({result.elapsed_ms} ms)")
                if result.error:
                    print(f"Error: {result.error}")
                else:
                    print(f"SQL: {result.sql}")
                    for line in format_diff(result.expected, result.actual):
                        print(line)
                    if args.rebaseline:
                        print()
                        print("Suggested update:")
                        print('            out="""')
                        for line in result.actual.splitlines():
                            print(f"                {line}")
                        print('            """,')
                failed_tests.append(name)

        elapsed_ms = int((time.time() - start_time) * 1000)
        passed = sum(1 for r in results if r.passed)
        failed = len(failed_tests)

        if args.verbose >= 1:
            print(f"[==========] {len(results)} tests ran. ({elapsed_ms} ms total)")

        if passed > 0:
            msg = colorize("[  PASSED  ]", Colors.GREEN)
            print(f"{msg} {passed} tests.")

        if failed > 0:
            msg = colorize("[  FAILED  ]", Colors.RED)
            print(f"{msg} {failed} tests, listed below:")
            for name in failed_tests:
                print(f"{msg} {name}")
            print(f"\n {failed} FAILED TESTS")

        return 0 if failed == 0 else 1

    finally:
        ctx.cleanup()


if __name__ == "__main__":
    sys.exit(main())
