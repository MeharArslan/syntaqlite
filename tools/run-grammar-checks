"""Grammar token-ordering integration checks.

Verifies that adding a dialect extension never shifts base SQLite token IDs:
  1. Generate a full amalgamation for sqlite and for each registered extension.
  2. Parse all `#define SYNTAQLITE_TK_*` lines from the generated headers.
  3. Assert every token shared between sqlite and the extension has the same ID.
  4. Assert every extension-only token has an ID strictly greater than the
     maximum base-sqlite token ID.

Usage:
    tools/run-grammar-checks [-v] [--binary PATH]
"""

import argparse
import re
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parent.parent

# ---------------------------------------------------------------------------
# Extension dialects to test.  Add entries here when new dialects are added.
# ---------------------------------------------------------------------------
EXTENSION_DIALECTS = [
    {
        "name": "perfetto",
        "actions_dir": str(ROOT_DIR / "dialects/perfetto/actions"),
        "nodes_dir": str(ROOT_DIR / "dialects/perfetto/nodes"),
    },
]

TOKEN_DEFINE_RE = re.compile(r"^#define\s+SYNTAQLITE_TK_(\w+)\s+(\d+)", re.MULTILINE)


def parse_token_ids(header_text: str) -> dict[str, int]:
    """Return {token_name: id} from a dialect amalgam header."""
    return {m.group(1): int(m.group(2)) for m in TOKEN_DEFINE_RE.finditer(header_text)}


def generate_full_amalg(cli: Path, name: str, output_dir: Path,
                        actions_dir: str | None = None,
                        nodes_dir: str | None = None) -> None:
    cmd = [str(cli), "dialect", "--name", name]
    if actions_dir:
        cmd += ["--actions-dir", actions_dir]
    if nodes_dir:
        cmd += ["--nodes-dir", nodes_dir]
    cmd += ["--output-type", "full", "--output-dir", str(output_dir)]
    proc = subprocess.run(cmd, capture_output=True, text=True)
    if proc.returncode != 0:
        raise RuntimeError(
            f"Failed to generate amalgamation for '{name}':\n{proc.stderr}"
        )


def check_extension(
    cli: Path,
    base_ids: dict[str, int],
    max_base_id: int,
    ext: dict,
    verbose: bool,
) -> list[str]:
    """Generate the extension amalgam and verify token ID invariants.

    Returns a list of error messages (empty = pass).
    """
    name = ext["name"]
    errors: list[str] = []

    with tempfile.TemporaryDirectory(prefix=f"syntaqlite_grammar_check_{name}_") as tmp:
        tmp_path = Path(tmp)
        try:
            generate_full_amalg(
                cli, name, tmp_path,
                actions_dir=ext.get("actions_dir"),
                nodes_dir=ext.get("nodes_dir"),
            )
        except RuntimeError as e:
            return [str(e)]

        header = tmp_path / f"syntaqlite_{name}.h"
        if not header.exists():
            return [f"Expected header not found: {header}"]

        ext_ids = parse_token_ids(header.read_text())

    if not ext_ids:
        return [f"No SYNTAQLITE_TK_* defines found in syntaqlite_{name}.h"]

    # 1. Shared tokens must have identical IDs.
    for tok, base_id in base_ids.items():
        if tok in ext_ids:
            ext_id = ext_ids[tok]
            if ext_id != base_id:
                errors.append(
                    f"  Token SYNTAQLITE_TK_{tok}: sqlite={base_id}, {name}={ext_id} "
                    f"(ID SHIFTED — extension file sorted before base files)"
                )

    # 2. Extension-only tokens must be above max base ID.
    for tok, ext_id in ext_ids.items():
        if tok not in base_ids:
            if ext_id <= max_base_id:
                errors.append(
                    f"  Extension-only token SYNTAQLITE_TK_{tok}={ext_id} "
                    f"is not above max base ID {max_base_id}"
                )
            elif verbose:
                print(f"    ext-only: SYNTAQLITE_TK_{tok}={ext_id} (max_base={max_base_id}) OK")

    return errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Grammar token-ordering checks")
    parser.add_argument(
        "--binary", default="target/debug/syntaqlite",
        help="Path to syntaqlite CLI binary (default: target/debug/syntaqlite)",
    )
    parser.add_argument("-v", "--verbose", action="store_true")
    args = parser.parse_args()

    cli = Path(args.binary)
    if not cli.is_absolute():
        cli = ROOT_DIR / cli

    if not cli.exists():
        print(f"ERROR: Binary not found: {cli}", file=sys.stderr)
        print("Build it first with: cargo build -p syntaqlite-cli", file=sys.stderr)
        return 1

    # --- Generate base sqlite amalgamation ---
    print("Generating sqlite amalgamation...", end=" ", flush=True)
    with tempfile.TemporaryDirectory(prefix="syntaqlite_grammar_check_sqlite_") as sqlite_tmp:
        try:
            generate_full_amalg(cli, "sqlite", Path(sqlite_tmp))
        except RuntimeError as e:
            print("FAILED")
            print(str(e), file=sys.stderr)
            return 1

        sqlite_header = Path(sqlite_tmp) / "syntaqlite_sqlite.h"
        if not sqlite_header.exists():
            print("FAILED")
            print(f"Expected header not found: {sqlite_header}", file=sys.stderr)
            return 1

        base_ids = parse_token_ids(sqlite_header.read_text())

    if not base_ids:
        print("FAILED")
        print("No SYNTAQLITE_TK_* defines found in sqlite amalgam header", file=sys.stderr)
        return 1

    max_base_id = max(base_ids.values())
    print(f"OK ({len(base_ids)} tokens, max id={max_base_id})")

    if args.verbose:
        for tok, tid in sorted(base_ids.items(), key=lambda x: x[1]):
            print(f"  SYNTAQLITE_TK_{tok}={tid}")

    # --- Check each extension dialect ---
    all_errors: dict[str, list[str]] = {}
    for ext in EXTENSION_DIALECTS:
        name = ext["name"]
        print(f"Checking extension '{name}'...", end=" ", flush=True)
        errors = check_extension(cli, base_ids, max_base_id, ext, args.verbose)
        if errors:
            print("FAILED")
            all_errors[name] = errors
        else:
            print("OK")

    # --- Report ---
    if all_errors:
        print()
        print("FAILURES:")
        for name, errors in all_errors.items():
            print(f"  [{name}]")
            for err in errors:
                print(err)
        return 1

    print()
    print(f"All grammar checks passed ({len(EXTENSION_DIALECTS)} extension(s) verified).")
    return 0


if __name__ == "__main__":
    sys.exit(main())
