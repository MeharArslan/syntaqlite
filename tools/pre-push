# Pre-push verification: all checks must pass before marking work done.
#
# Usage:
#   tools/pre-push          — run all checks (headers only, output on failure)
#   tools/pre-push --fix    — auto-fix what's possible, then run remaining checks
#   tools/pre-push -q       — quiet: no output unless a step fails (for agents)
#   tools/pre-push -v       — verbose: step headers + full command output
#
# Build cache strategy: the --all-features clippy step uses an isolated target
# directory (target/clippy-all-features) so it doesn't invalidate the cache for
# subsequent steps that run with default/no-default features. RUSTFLAGS are
# never changed mid-script, avoiding full-workspace cache invalidation.
#
# All cargo invocations go through tools/cargo (hermetic toolchain) to keep
# RUSTFLAGS consistent and avoid cross-tool cache invalidation.
#
# Steps:
#   1. cargo fmt (--check or apply)              — Rust formatting
#   2. cargo clippy --all-features               — lint + type-check (all features)
#   3. cargo clippy (default features)           — dead code: default features
#   4. cargo clippy --no-default-features        — dead code: no default features
#   5. tools/format-c (--check or apply)         — C formatting
#   6. tools/check-c-deps                        — C header dependency boundaries
#   7. tools/check-public-api                    — public API golden file gate
#   8. tools/run-unit-tests                      — Rust unit tests
#   9. cargo build -p syntaqlite-cli             — build CLI for diff tests
#  10. tools/run-ast-diff-tests                  — AST diff tests
#  11. tools/run-fmt-diff-tests                  — formatter diff tests
#  12. tools/run-amalg-tests                     — amalgamation integration tests
#  13. tools/run-perfetto-fmt-diff-tests          — Perfetto formatter diff tests
#  14. tools/run-perfetto-validation-diff-tests   — Perfetto validation diff tests
#  15. tools/build-web-playground                — WASM playground (if emscripten installed)

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
CARGO="$SCRIPT_DIR/cargo"

cd "$ROOT_DIR"

FIX=0
# Verbosity: -1=quiet (agents), 0=headers only (default), 1=headers+output
VERBOSITY=0
for arg in "$@"; do
    case "$arg" in
        --fix) FIX=1 ;;
        -q|--quiet) VERBOSITY=-1 ;;
        -v|--verbose) VERBOSITY=1 ;;
    esac
done

# run_step DESC CMD [ARGS...]
#   -q: no output on success; on failure print step name + captured output
#    0: print step header; command output only on failure
#   -v: print step header + live command output
run_step() {
    desc="$1"
    shift
    if [ "$VERBOSITY" -ge 1 ]; then
        printf '\n\033[1;34m==> %s\033[0m\n' "$desc"
        "$@"
    elif [ "$VERBOSITY" -ge 0 ]; then
        printf '\033[1;34m==> %s\033[0m\n' "$desc"
        if output=$("$@" 2>&1); then
            return 0
        else
            rc=$?
            printf '\033[1;31m    FAILED. Output:\033[0m\n'
            printf '%s\n' "$output"
            exit $rc
        fi
    else
        if output=$("$@" 2>&1); then
            return 0
        else
            rc=$?
            printf '\033[1;31m==> FAILED: %s\033[0m\n' "$desc"
            printf '%s\n' "$output"
            exit $rc
        fi
    fi
}

DEAD_CODE_LINTS="-D dead_code -D unused_imports -D unused_variables -D unused_mut"

# 1. Rust formatting
if [ "$FIX" = "1" ]; then
    run_step "cargo fmt" "$CARGO" fmt
else
    run_step "cargo fmt --check" "$CARGO" fmt --check
fi

# 2. Clippy — all features (type-check + lint; -D warnings covers dead_code etc.)
#    Isolated target dir: --all-features enables a different feature set for
#    build deps (e.g. syntaqlite-buildtools), which would invalidate the cache
#    used by subsequent default-features steps.
CLIPPY_ALL_TARGET_DIR="$ROOT_DIR/target/clippy-all-features"
if [ "$FIX" = "1" ]; then
    run_step "cargo clippy --fix --all-features" \
        "$CARGO" clippy --tests --all-features --all-targets --fix --allow-dirty --allow-staged \
        --target-dir "$CLIPPY_ALL_TARGET_DIR" -- -D warnings
    # Re-format after clippy --fix may have changed code
    run_step "cargo fmt (post-clippy-fix)" "$CARGO" fmt
else
    run_step "cargo clippy --all-features" \
        "$CARGO" clippy --tests --all-features --all-targets \
        --target-dir "$CLIPPY_ALL_TARGET_DIR" -- -D warnings
fi

# 3-4. Dead code for remaining feature combos (clippy reuses its own cache —
#       no RUSTFLAGS change, no full rebuild).
run_step "dead code check: default features" \
    "$CARGO" clippy --all-targets -- $DEAD_CODE_LINTS

run_step "dead code check: no default features" \
    "$CARGO" clippy --all-targets --no-default-features -- $DEAD_CODE_LINTS

# 5. C formatting
if [ "$FIX" = "1" ]; then
    run_step "tools/format-c" "$SCRIPT_DIR/format-c"
else
    run_step "tools/format-c --check" "$SCRIPT_DIR/format-c" --check
fi

# 6. C header dependency boundaries
run_step "tools/check-c-deps" "$SCRIPT_DIR/check-c-deps"

# 7. Public API golden file gate
run_step "tools/check-public-api" "$SCRIPT_DIR/check-public-api"

# 8. Unit tests
run_step "tools/run-unit-tests" "$SCRIPT_DIR/run-unit-tests"

# 9. Build CLI for diff tests
run_step "cargo build -p syntaqlite-cli" "$CARGO" build -p syntaqlite-cli

# 10-14. Diff test suites
run_step "tools/run-ast-diff-tests" "$SCRIPT_DIR/run-ast-diff-tests"

run_step "tools/run-fmt-diff-tests" "$SCRIPT_DIR/run-fmt-diff-tests"

run_step "tools/run-amalg-tests" "$SCRIPT_DIR/run-amalg-tests"

run_step "tools/run-perfetto-fmt-diff-tests" "$SCRIPT_DIR/run-perfetto-fmt-diff-tests"

run_step "tools/run-perfetto-validation-diff-tests" "$SCRIPT_DIR/run-perfetto-validation-diff-tests"

# 15. Web playground WASM build (requires emscripten)
case "$(uname -s)-$(uname -m)" in
    Darwin-arm64|Darwin-aarch64) _PLAT_DIR="mac-arm64" ;;
    Darwin-x86_64)               _PLAT_DIR="mac-amd64" ;;
    Linux-aarch64)               _PLAT_DIR="linux-arm64" ;;
    Linux-x86_64)                _PLAT_DIR="linux-amd64" ;;
    *)                           _PLAT_DIR="" ;;
esac
if [ -n "$_PLAT_DIR" ] && [ -d "$ROOT_DIR/third_party/bin/$_PLAT_DIR/emscripten" ]; then
    run_step "tools/build-web-playground" "$SCRIPT_DIR/build-web-playground"
else
    printf '\n\033[1;33m==> tools/build-web-playground (skipped — emscripten not installed)\033[0m\n'
fi

printf '\n\033[1;32mAll pre-push checks passed.\033[0m\n'
