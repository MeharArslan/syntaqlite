# Pre-push verification: all checks must pass before marking work done.
#
# Steps:
#   1. cargo fmt --check                       — Rust formatting
#   2. cargo check                             — type-check all crates
#   3. cargo clippy                            — lint (zero warnings)
#   4. tools/format-c --check                  — C formatting
#   5. tools/check-c-deps                      — C header dependency boundaries
#   6. tools/run-unit-tests                    — Rust unit tests
#   7. cargo build -p syntaqlite-cli           — build CLI for diff tests
#   8. tools/run-ast-diff-tests                — AST diff tests
#   9. tools/run-fmt-diff-tests                — formatter diff tests
#  10. tools/run-amalg-tests                   — amalgamation integration tests
#  11. tools/run-perfetto-fmt-diff-tests        — Perfetto formatter diff tests
#  12. tools/run-perfetto-validation-diff-tests — Perfetto validation diff tests

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$ROOT_DIR"

step() {
    printf '\n\033[1;34m==> %s\033[0m\n' "$*"
}

# 1. Rust formatting
step "cargo fmt --check"
cargo fmt --check

# 2. Type check
step "cargo check"
cargo check

# 3. Clippy (zero warnings)
step "cargo clippy -- -D warnings"
cargo clippy -- -D warnings

# 4. C formatting
step "tools/format-c --check"
"$SCRIPT_DIR/format-c" --check

# 5. C header dependency boundaries
step "tools/check-c-deps"
"$SCRIPT_DIR/check-c-deps"

# 6. Unit tests
step "tools/run-unit-tests"
"$SCRIPT_DIR/run-unit-tests"

# 7. Build CLI for diff tests
step "cargo build -p syntaqlite-cli"
cargo build -p syntaqlite-cli

# 8-12. Diff test suites
step "tools/run-ast-diff-tests"
"$SCRIPT_DIR/run-ast-diff-tests"

step "tools/run-fmt-diff-tests"
"$SCRIPT_DIR/run-fmt-diff-tests"

step "tools/run-amalg-tests"
"$SCRIPT_DIR/run-amalg-tests"

step "tools/run-perfetto-fmt-diff-tests"
"$SCRIPT_DIR/run-perfetto-fmt-diff-tests"

step "tools/run-perfetto-validation-diff-tests"
"$SCRIPT_DIR/run-perfetto-validation-diff-tests"

printf '\n\033[1;32mAll pre-push checks passed.\033[0m\n'
